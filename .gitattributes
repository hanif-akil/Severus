# Ensure shell scripts use LF line endings
*.sh text eol=lf
gradlew text eol=lf

# Ensure batch files use CRLF line endings
*.bat text eol=crlf

# Ensure Gradle files use LF line endings
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradle.properties text eol=lf

# Ensure binary files stay binary
*.jar binary
*.png binary
*.jpg binary
*.gif binary
