<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/clipboard_panel_background"
    android:padding="8dp"
    android:layout_margin="4dp">

    <TextView
        android:id="@+id/clipboard_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clipboard"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="?android:attr/textColorPrimary" />

    <TextView
        android:id="@+id/clipboard_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No clipboard items"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="20dp"
        android:textColor="?android:attr/textColorSecondary"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/clipboard_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="240dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/clipboard_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
