<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/functionalKeyBackground"
    android:padding="4dp">

    <TextView
        android:id="@+id/clipboard_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clipboard"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/clipboard_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No clipboard items"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/clipboard_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/clipboard_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
