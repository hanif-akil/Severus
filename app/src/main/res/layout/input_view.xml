<rkr.simplekeyboard.inputmethod.latin.InputView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="?attr/inputViewStyle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/toolbar_container"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="#FF333333">

            <ImageView
                android:id="@+id/toolbar_clipboard"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:src="@drawable/sym_keyboard_clipboard"
                android:scaleType="centerInside"
                android:contentDescription="Clipboard"
                android:background="@android:color/transparent" />

            <ImageView
                android:id="@+id/toolbar_settings"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:src="@drawable/sym_keyboard_settings"
                android:scaleType="centerInside"
                android:contentDescription="Settings"
                android:background="@android:color/transparent" />

            <ImageView
                android:id="@+id/toolbar_numpad"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:src="@drawable/sym_keyboard_numpad"
                android:scaleType="centerInside"
                android:contentDescription="Number pad"
                android:background="@android:color/transparent" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/clipboard_popup_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <rkr.simplekeyboard.inputmethod.keyboard.MainKeyboardView
            android:id="@+id/keyboard_view"
            android:layoutDirection="ltr"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</rkr.simplekeyboard.inputmethod.latin.InputView>
